# ─── Runtime (bắt buộc khi chạy API) ───────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

JWT_SECRET=your-jwt-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

PORT=3000

# ─── Seed script only (pnpm seed) ────────────────────────────────────────────
# Connection string Postgres trực tiếp — không dùng Supabase client
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Số lượng bản ghi seed (tùy chọn)
SEED_CATEGORIES=8
SEED_TAGS=30
SEED_USERS=100
SEED_BADGES=20
SEED_QUIZZES=80

# Xóa toàn bộ dữ liệu trước khi seed (true/false)
TRUNCATE_BEFORE=false
